# Chemistry Synthesis Planning API — Environment Variables
# Copy this file to .env and adjust values before deployment.

# ── Authentication ──
# Set to a long random secret in production. If unset, API runs in dev mode (no auth).
API_KEY=dev-key-change-in-production

# ── Services ──
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database ──
MONGO_URL=mongodb://localhost:27017
DB_NAME=rxn1

# ── Learning engine ──
FEEDBACK_RETRAIN_THRESHOLD=25

# ── CORS (comma-separated origins, or * for all) ──
CORS_ORIGINS=*